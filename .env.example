# Copy to .env (gitignored) and fill in real values.

# ─── crm-api ────────────────────────────────────────────────────────────────
# SQLAlchemy + psycopg v3 URL. Neon example:
#   postgresql+psycopg://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Local Postgres example:
#   postgresql+psycopg://pulse:pulse@localhost:5432/pulse
DATABASE_URL=postgresql+psycopg://user:password@host:5432/pulse

# Anthropic Claude API key (used by Strategist/compose/debrief in Phase 3+).
ANTHROPIC_API_KEY=sk-ant-xxx

# Where crm-api dispatches sends to. Local default below.
CHANNEL_SERVICE_URL=http://localhost:8001

# ─── channel-service ────────────────────────────────────────────────────────
# Where channel-service POSTs receipt callbacks back to crm-api.
CRM_RECEIPT_URL=http://localhost:8000/receipts

# ─── pulse-web (frontend) ───────────────────────────────────────────────────
# Frontend reads this at build time (Vite). Not used by the backend.
VITE_API_BASE_URL=http://localhost:8000
